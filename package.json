{
  "name": "@bluenexus/bluenexus-openclaw-plugin",
  "version": "0.1.2",
  "license": "MIT",
  "description": "OpenClaw plugin for BlueNexus Universal MCP - connect OpenClaw agents to BlueNexus services",
  "type": "module",
  "files": ["dist", "openclaw.plugin.json"],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean:node_modules": "rm -rf node_modules",
    "clean:dist": "rm -rf dist",
    "dev": "vitest",
    "build": "node esbuild.config.mjs",
    "check": "pnpm run check:biome && pnpm run check:types",
    "check:biome": "pnpm exec biome check --error-on-warnings",
    "check:types": "tsc --noEmit",
    "fix": "pnpm exec biome check --fix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@sinclair/typebox": "^0.34.33",
    "@types/node": "^22.19.7",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "undici": "^7.3.0",
    "vitest": "^3.1.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "bluenexus",
    "mcp",
    "model-context-protocol",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluenexus-ai/openclaw.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/bluenexus-ai/openclaw#readme",
  "bugs": {
    "url": "https://github.com/bluenexus-ai/openclaw/issues"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c"
}
